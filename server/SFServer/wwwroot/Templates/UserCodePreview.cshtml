@model SFServer.Models.DTO.UserViewDTO
<!doctype html>
<html lang="en">
<head>
    <link rel="apple-touch-icon" sizes="180x180" href="../static/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="../static/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="../static/favicon-16x16.png">
    <link rel="manifest" href="../static/site.webmanifest">
    <link rel="mask-icon" href="../static/safari-pinned-tab.svg" color="#22bb1c">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">
    <meta property="og:title" content="Safari Forever">
    <meta property="og:description" content="@Model.Description">
    <meta property="og:image:width" content="512">
    <meta property="og:image:height" content="512">
    <meta property="og:url" content="https://safariforever.com">
    <meta name="twitter:card" content="summary">

    <title>Safari Forever</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale = 1.0" />

    <meta name="description" content="Safari Forever Profile Preview">
    <meta name="author" content="Johannes Stensen">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
</head>
<style>
    html {
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        position: relative;
        margin: 0;
        padding: 0;
        background-image: url("../static/background2.png");
        background-repeat: repeat;
    }

    /* REMOVED: palamecia font files were removed before open-sourcing (commercial/unknown license).
       Replace with a suitable web font and update the font-family references below. */
    /* REMOVED: superfruit font also removed — update #levelPlateContainer font-family 'superfruitbold'. */

    .aspect-ratio--16x9 {
        width: 50.625vh; /* ratio = 9/16 * 90 = 50.625 */
        height: 90vh; /* 90% of viewport vidth */
        max-height: 160vw; /* 16/9 * 90 = 160 */
        max-width: 90vw;
        margin: auto;
        position: absolute;
        top: 2vh;
        left: 0;
        right: 0;
    }

    #inner-wrapper {
        width: 100%;
        height: 100%;
    }

    #inner-wrapper > * {
        width: 100%;
        max-width: 100%;
        margin-right: auto; /* 1 */
        margin-left: auto; /* 1 */
    }

    #logo {
        position: relative;
        width: 80%;
        left: 10%;
        margin-bottom: 10%;
    }

    a {
        text-decoration: none;
        color: #2E2E2E;
    }

    #playButton {
        width: 75%;
        height: 10%;
        margin-right: auto;
        margin-left: auto;
        display:block;
    }

    #buttonPusher {
        width: 100%;
        height: 0px;
    }

    #playButtonSurface {
        width: 100%;
        height: 85%;
        background-color: white;
        border-radius: 15px;
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'palameciaregular';
        font-weight: bold;
    }

    #playButtonBackground {
        width: 100%;
        height: 100%;
        background-color: #2E2E2E;
        opacity: 0.5;
        border-radius: 15px;
        margin-top: -20%;
    }

    #playButton:active > #buttonPusher {
        height: 10%;
    }

    #playButton:active > #playButtonSurface {
        background-color: #eee;
    }

    #playButton:active > #playButtonBackground {
        height: 90%;
    }

    #nickname {
        font-family: 'palameciaregular';
        font-weight: bold;
        color: white;
        text-align: center;
        margin-bottom: 3%;
    }

    #followerPlateContainer {
        height: 7.5%;
        width: 75%;
        margin-right: auto;
        margin-left: auto;
        margin-bottom: 4%;
        font-family: 'palameciaregular';
        font-weight: bold;
        color: white;
        position: relative;
    }

    #followerPlateBox {
        position: absolute;
        height: 100%;
        width: 100%;
        background-color: #000000;
        opacity:0.6;
        border-radius: 15px;
        z-index: -1;
    }

    #followerPlateContainer > p:nth-child(2) {
        float: left;
        padding: 0 0 0 4%;
        margin: 5% 0 0 0;
    }

    #followerPlateContainer > p:nth-child(3) {
        float: right;
        padding: 0 4% 0 0;
        margin: 5% 0 0 0;
        direction: rtl;
    }

    #levelPlateContainer {
        height: 15%;
        width: 75%;
        margin-right: auto;
        margin-left: auto;
        margin-bottom: 31%;
        font-family: 'superfruitbold';
        font-weight: bold;
        color: white;
        position:relative;
    }

    #levelPlateBox {
        position: absolute;
        height: 100%;
        width: 100%;
        background-color: #000000;
        opacity: 0.6;
        border-radius: 15px;
        z-index: -1;
    }

    #levelPlateContainer > p {
        position: relative;
        display: block;
        margin: 0;
        padding-left: 7%;
        padding-top: 3%;
    }

    #levelList {
        height: 100%;
        padding-left: 6.5%;
    }

    .levelPreview {
        height: 50%;
        border-radius: 20%;
        margin-top: 1%;
        margin-right: 3%;
        border: 0.5vmin solid #FFF;
    }

</style>
<body bgcolor="@Model.Color">
    <div class="aspect-ratio--16x9">
        <div id="inner-wrapper">
            <img id="logo" src="../static/SafariLogo.png" alt="safari forever logo" />

            <h2 id="nickname">@Model.NicknameAndIdentfier</h2>
            <div id="followerPlateContainer">
                <div id="followerPlateBox"></div>
                <p>Followers:</p>
                <p>@Model.FollowerCount</p>
            </div>

            <div id="levelPlateContainer">
                <div id="levelPlateBox"></div>
                <p id="levelsBy">Levels by @Model.Nickname:</p>
                <div id="levelList">
                    <a href="https://play.safariforever.com/@Model.Levels[0]">
                        <img class="levelPreview" src="https://play.safariforever.com/level/@Model.Levels[0]/img" alt="level preview image" style="display: @Model.DisplayValues[0]" ; />
                    </a>
                    <a href="https://play.safariforever.com/@Model.Levels[1]">
                        <img class="levelPreview" src="https://play.safariforever.com/level/@Model.Levels[1]/img" alt="level preview image" style="display: @Model.DisplayValues[1]" ; />
                    </a>
                    <a href="https://play.safariforever.com/@Model.Levels[2]">
                        <img class="levelPreview" src="https://play.safariforever.com/level/@Model.Levels[2]/img" alt="level preview image" style="display: @Model.DisplayValues[2]" ; />
                    </a>
                    <a href="https://play.safariforever.com/@Model.Levels[3]">
                        <img class="levelPreview" src="https://play.safariforever.com/level/@Model.Levels[3]/img" alt="level preview image" style="display: @Model.DisplayValues[3]" ; />
                    </a>
                </div>
            </div>

            <div id="playButton" onclick="OnClickPlay()">
                <div id="buttonPusher"></div>
                <div id="playButtonSurface">View ingame</div>
                <div id="playButtonBackground"></div>
            </div>

        </div>
    </div>

    <script src="../static/fittext.js"></script>
    <script>
        fitText(document.getElementById('playButtonSurface'), 0.8);
        fitText(document.getElementById('nickname'), 1);
        fitText(document.getElementById('followerPlateContainer'), 1);
        fitText(document.getElementById('levelsBy'), 1.6);

        var isMobile = function() {
            var check = false;
            (function(a){if(/(android|bb\d+|meego).+mobile|avantgo|bada\/|blackberry|blazer|compal|elaine|fennec|hiptop|iemobile|ip(hone|od)|iris|kindle|lge |maemo|midp|mmp|mobile.+firefox|netfront|opera m(ob|in)i|palm( os)?|phone|p(ixi|re)\/|plucker|pocket|psp|series(4|6)0|symbian|treo|up\.(browser|link)|vodafone|wap|windows ce|xda|xiino|android|ipad|playbook|silk/i.test(a)||/1207|6310|6590|3gso|4thp|50[1-6]i|770s|802s|a wa|abac|ac(er|oo|s\-)|ai(ko|rn)|al(av|ca|co)|amoi|an(ex|ny|yw)|aptu|ar(ch|go)|as(te|us)|attw|au(di|\-m|r |s )|avan|be(ck|ll|nq)|bi(lb|rd)|bl(ac|az)|br(e|v)w|bumb|bw\-(n|u)|c55\/|capi|ccwa|cdm\-|cell|chtm|cldc|cmd\-|co(mp|nd)|craw|da(it|ll|ng)|dbte|dc\-s|devi|dica|dmob|do(c|p)o|ds(12|\-d)|el(49|ai)|em(l2|ul)|er(ic|k0)|esl8|ez([4-7]0|os|wa|ze)|fetc|fly(\-|_)|g1 u|g560|gene|gf\-5|g\-mo|go(\.w|od)|gr(ad|un)|haie|hcit|hd\-(m|p|t)|hei\-|hi(pt|ta)|hp( i|ip)|hs\-c|ht(c(\-| |_|a|g|p|s|t)|tp)|hu(aw|tc)|i\-(20|go|ma)|i230|iac( |\-|\/)|ibro|idea|ig01|ikom|im1k|inno|ipaq|iris|ja(t|v)a|jbro|jemu|jigs|kddi|keji|kgt( |\/)|klon|kpt |kwc\-|kyo(c|k)|le(no|xi)|lg( g|\/(k|l|u)|50|54|\-[a-w])|libw|lynx|m1\-w|m3ga|m50\/|ma(te|ui|xo)|mc(01|21|ca)|m\-cr|me(rc|ri)|mi(o8|oa|ts)|mmef|mo(01|02|bi|de|do|t(\-| |o|v)|zz)|mt(50|p1|v )|mwbp|mywa|n10[0-2]|n20[2-3]|n30(0|2)|n50(0|2|5)|n7(0(0|1)|10)|ne((c|m)\-|on|tf|wf|wg|wt)|nok(6|i)|nzph|o2im|op(ti|wv)|oran|owg1|p800|pan(a|d|t)|pdxg|pg(13|\-([1-8]|c))|phil|pire|pl(ay|uc)|pn\-2|po(ck|rt|se)|prox|psio|pt\-g|qa\-a|qc(07|12|21|32|60|\-[2-7]|i\-)|qtek|r380|r600|raks|rim9|ro(ve|zo)|s55\/|sa(ge|ma|mm|ms|ny|va)|sc(01|h\-|oo|p\-)|sdk\/|se(c(\-|0|1)|47|mc|nd|ri)|sgh\-|shar|sie(\-|m)|sk\-0|sl(45|id)|sm(al|ar|b3|it|t5)|so(ft|ny)|sp(01|h\-|v\-|v )|sy(01|mb)|t2(18|50)|t6(00|10|18)|ta(gt|lk)|tcl\-|tdg\-|tel(i|m)|tim\-|t\-mo|to(pl|sh)|ts(70|m\-|m3|m5)|tx\-9|up(\.b|g1|si)|utst|v400|v750|veri|vi(rg|te)|vk(40|5[0-3]|\-v)|vm40|voda|vulc|vx(52|53|60|61|70|80|81|83|85|98)|w3c(\-| )|webc|whit|wi(g |nc|nw)|wmlb|wonu|x700|yas\-|your|zeto|zte\-/i.test(a.substr(0,4))) check = true;})(navigator.userAgent||navigator.vendor||window.opera);
            return check;
        };

        function OnClickPlay() {
            if (isMobile()) {
                location.href = "@Model.PlayButtonUrl";
            }
            else {
                location.href = "https://safariforever.com";
            }
        }
    </script>
</body>
</html>